---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "China Basin Community Archive - Information Portal" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content="noindex, nofollow">
		<meta name="googlebot" content="noindex, nofollow">
		<link rel="icon" type="image/svg+xml" href="/cb-archive/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | China Basin Community Archive</title>
		<meta name="description" content={description} />
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
			<nav class="container mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/cb-archive/" class="text-xl font-bold text-blue-800">China Basin Community Archive</a>
				<ul class="hidden md:flex space-x-6 text-sm font-medium">
					<li><a href="/cb-archive/governing" class="hover:text-blue-600 transition">Governing Docs</a></li>
					<li><a href="/cb-archive/policies" class="hover:text-blue-600 transition">Policies</a></li>
					<li><a href="/cb-archive/contracts" class="hover:text-blue-600 transition">Contracts</a></li>
					<li><a href="/cb-archive/financials" class="hover:text-blue-600 transition">Financials</a></li>
					<li><a href="/cb-archive/history" class="hover:text-blue-600 transition">History</a></li>
					<li><a href="/cb-archive/parking" class="hover:text-blue-600 transition">Parking</a></li>
				</ul>
			</nav>
		</header>

		<main class="flex-grow container mx-auto px-4 py-8" data-pagefind-body>
			<slot />
		</main>

		<footer class="bg-slate-100 border-t border-slate-200 py-10">
			<div class="container mx-auto px-4 text-center text-slate-500 text-sm space-y-4">
				<div class="bg-white/50 border border-slate-200 rounded-lg p-4 max-w-2xl mx-auto italic text-slate-400">
					<p><strong>Disclaimer:</strong> This is a volunteer project run by a fellow homeowner. Content was parsed using NotebookLM (AI tool) and may contain errors. Please reference the official documents for accuracy. This portal was created using Gemini CLI.</p>
				</div>
				<p>© {new Date().getFullYear()} China Basin Community Archive. Created for transparency.</p>
			</div>
		</footer>
	</body>
</html>
