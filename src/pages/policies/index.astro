---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allDocs = await getCollection('policies');

// Separate the pinned "Rules and Regulations" from the rest
const pinnedDoc = allDocs.find(doc => doc.id === 'rules-regulations');
const otherDocs = allDocs.filter(doc => doc.id !== 'rules-regulations');
---

<BaseLayout title="Current Policies">
	<div class="mb-12">
		<h1 class="text-4xl font-extrabold text-slate-900 mb-4">Current Policies</h1>
		<p class="text-lg text-slate-600 max-w-3xl">
			Active rules and operational guidelines for our community. Ensure you are familiar 
			with these standards to maintain a harmonious living environment.
		</p>
	</div>

	{pinnedDoc && (
		<section class="mb-16">
			<h2 class="text-xs uppercase tracking-widest font-black text-blue-600 mb-4">Primary Governance</h2>
			<div class="bg-blue-700 rounded-3xl p-8 md:p-12 text-white shadow-xl shadow-blue-200 relative overflow-hidden group">
				<div class="absolute -right-10 -bottom-10 text-9xl opacity-10 group-hover:scale-110 transition-transform duration-700">📜</div>
				<div class="max-w-2xl relative z-10">
					<h3 class="text-3xl md:text-4xl font-bold mb-4">{pinnedDoc.data.title}</h3>
					<p class="text-blue-100 text-lg mb-8 leading-relaxed">
						{pinnedDoc.data.description}
					</p>
					
					{pinnedDoc.data.keyTakeaways && (
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
							{pinnedDoc.data.keyTakeaways.slice(0, 4).map(t => (
								<div class="flex items-center gap-3 bg-blue-800/50 p-3 rounded-xl border border-blue-400/30">
									<span class="text-blue-300 italic">★</span>
									<span class="text-sm font-medium">{t}</span>
								</div>
							))}
						</div>
					)}

					<a href={`/cb-archive/policies/${pinnedDoc.id}`} class="inline-block bg-white text-blue-800 px-8 py-3 rounded-full font-bold hover:bg-blue-50 transition shadow-lg">
						Read Master Rules →
					</a>
				</div>
			</div>
		</section>
	)}

	<section>
		<h2 class="text-xs uppercase tracking-widest font-black text-slate-400 mb-6">All Community Policies</h2>
		<div class="grid grid-cols-1 gap-6">
			{otherDocs.length === 0 ? (
				<p class="italic text-slate-500">No additional policy documents found.</p>
			) : (
				otherDocs.map(doc => (
					<div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md hover:border-blue-200 transition flex flex-col md:flex-row md:items-center justify-between gap-6">
						<div class="max-w-2xl">
							<h3 class="text-xl font-bold text-slate-900 mb-1">{doc.data.title}</h3>
							<p class="text-slate-600 text-sm mb-4 leading-relaxed">{doc.data.description}</p>
							<a href={`/cb-archive/policies/${doc.id}`} class="text-blue-700 font-semibold text-sm hover:underline flex items-center gap-1">
								View Details <span class="text-xs">→</span>
							</a>
						</div>
						
						{doc.data.cost && (
							<div class="bg-slate-50 border border-slate-100 px-6 py-4 rounded-xl text-center min-w-[160px]">
								<span class="block text-[10px] uppercase tracking-wider text-slate-400 font-bold mb-1">Fee/Deposit</span>
								<span class="text-lg font-bold text-slate-900">{doc.data.cost}</span>
							</div>
						)}
					</div>
				))
			)}
		</div>
	</section>
</BaseLayout>
