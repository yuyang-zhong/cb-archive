---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = await getCollection('history');
---
<BaseLayout title="Building History">
	<div class="mb-12">
		<h1 class="text-4xl font-extrabold text-slate-900 mb-4">Building History & Construction</h1>
		<p class="text-lg text-slate-600 max-w-3xl">Archives of our community's development from groundbreaking to today.</p>
	</div>
	<div class="space-y-6">
		{docs.length === 0 ? <p class="italic text-slate-500">No history records found.</p> : docs.map(doc => (
			<div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
				<h2 class="text-xl font-bold mb-2">{doc.data.title}</h2>
				<p class="text-slate-600 mb-4">{doc.data.description}</p>
				<a href={`/history/${doc.id}`} class="text-blue-700 font-semibold hover:underline">Explore History →</a>
			</div>
		))}
	</div>
</BaseLayout>
