---
import BaseLayout from '../../layouts/BaseLayout.astro';
import closings from '../../data/closings.json';

const totalUnits = 148;
const currentClosed = closings[closings.length - 1].total;
const absorptionRate = ((currentClosed / totalUnits) * 100).toFixed(1);

// Chart dimensions & logic
const chartHeight = 200;
const chartWidth = 800;
const maxTotal = 150; // Max Y value

const points = closings.map((d, i) => {
  const x = (i / (closings.length - 1)) * chartWidth;
  const y = chartHeight - (d.total / maxTotal) * chartHeight;
  return `${x},${y}`;
}).join(' ');

const timelineEvents = [
  // 2019-2022
  { date: "Sept – Nov 2019", category: "funding", year: "2019", text: "Project pre-development activities ramp up, including the issuance of an Equity/Construction Financing RFP and the submission of applications for CDLAC and TCAC funding.", yearRange: "Pre-Construction & Entitlements" },
  { date: "February 2020", category: "funding", year: "2020", text: "The Gap Financing Application is submitted.", yearRange: "Pre-Construction & Entitlements" },
  { date: "April 7, 2020", category: "funding", year: "2020", text: "The OCII Commission authorizes a $3.5 million Predevelopment Loan Agreement and an Exclusive Negotiations Agreement (ENA) with 350 China Basin Partners, LLC.", yearRange: "Pre-Construction & Entitlements" },
  { date: "Feb 16, 2021", category: "progress", year: "2021", text: "The Project's Basic Concept and Schematic Design is conditionally approved, along with amendments to allow a 90-foot height limit on street-fronting facades.", yearRange: "Pre-Construction & Entitlements" },
  { date: "Oct 15, 2021", category: "funding", year: "2021", text: "The Citywide Affordable Housing Loan Committee evaluates and recommends approval for the project's loan and gap funding.", yearRange: "Pre-Construction & Entitlements" },
  { date: "Dec 7, 2021", category: "funding", year: "2021", text: "The Commission approves an additional $1.5 million in predevelopment financing (totaling $5 million) to fund design, engineering, and the indicator pile program.", yearRange: "Pre-Construction & Entitlements" },
  { date: "April 19, 2022", category: "funding", year: "2022", text: "OCII formally authorizes the Disposition and Development Agreement (DDA) and an Amended and Restated Loan Agreement for $75,184,522 to fund construction.", yearRange: "Pre-Construction & Entitlements" },
  
  // Mid-Late 2022
  { date: "June 28, 2022", category: "funding", year: "2022", text: "A Final Financial Plan Memorandum is issued to the Directors of OCII and MOHCD, officially confirming the project's financial plan prior to closing.", yearRange: "Foundation & Foundation Work" },
  { date: "Late June 2022", category: "progress", year: "2022", text: "The Disposition and Development Agreement (DDA) and Amended & Restated Loan Agreement are fully executed and notarized by the Developer, OCII, and MOHCD.", yearRange: "Foundation & Foundation Work" },
  { date: "July 18, 2022", category: "progress", year: "2022", text: "The official Notice to Proceed (NTP) is issued, marking the start of construction. Indicator pile driving begins the same week.", yearRange: "Foundation & Foundation Work" },
  { date: "October 2022", category: "progress", year: "2022", text: "Temporary power is energized by PG&E, and pile driving equipment is demobilized as the foundation piles are completed.", yearRange: "Foundation & Foundation Work" },
  { date: "December 2022", category: "progress", year: "2022", text: "The tower crane is successfully erected, inspected, and becomes fully operational.", yearRange: "Foundation & Foundation Work" },

  // 2023
  { date: "Jan – Mar 2023", category: "delay", year: "2023", text: "Severe winter storms cause significant schedule impacts. Critical path activities, particularly the transformer room waterproofing and slab-on-grade pours, are substantially delayed. To mitigate delays, the team authorizes overtime work.", yearRange: "Structural Progress" },
  { date: "May 2023", category: "progress", year: "2023", text: "The personnel hoist (man lift) is erected and certified by CAL OSHA, and the Level 2 decks and walls are actively being poured.", yearRange: "Structural Progress" },
  { date: "July 31, 2023", category: "delay", year: "2023", text: "The first mock-up window water test fails. A manufacturer defect is identified a week later. This sparks a months-long cycle of remediation and re-testing.", yearRange: "Structural Progress" },

  // 2024
  { date: "Jan 16, 2024", category: "funding", year: "2024", text: "OCII authorizes and executes a First Amendment to the Loan Agreement, injecting an additional $8 million in gap funding (totaling $83,184,522).", yearRange: "Marketing & Closeout" },
  { date: "January 2024", category: "delay", year: "2024", text: "The contractor formally reports an 8-week delay caused by a design issue regarding deflection joints at the window heads. Net impact is 4 weeks.", yearRange: "Marketing & Closeout" },
  { date: "March 24, 2024", category: "marketing", year: "2024", text: "The developer submits the finalized Below Market Rate (BMR) Ownership Marketing Plan for the 148 units.", yearRange: "Marketing & Closeout" },
  { date: "April 5, 2024", category: "marketing", year: "2024", text: "The official marketing launch begins for the initial BMR lottery.", yearRange: "Marketing & Closeout" },
  { date: "Apr – May 2024", category: "progress", year: "2024", text: "Installation of the PG&E #6 vault in Mission Rock Street begins. Multiple open houses and information sessions are hosted.", yearRange: "Marketing & Closeout" },
  { date: "May 4-8, 2024", category: "delay", year: "2024", text: "An unseasonal rain event prevents the application of hot fluid-applied waterproofing on the Level 2 courtyard, causing an additional 3-day critical path delay.", yearRange: "Marketing & Closeout" },
  { date: "May 31, 2024", category: "lottery", year: "2024", text: "The deadline closes for the initial BMR lottery applications.", yearRange: "Marketing & Closeout" },
  { date: "June 21 – 26, 2024", category: "lottery", year: "2024", text: "The housing lottery is conducted to select the initial homebuyers.", yearRange: "Marketing & Closeout" },
  { date: "July 3, 2024", category: "lottery", year: "2024", text: "The BMR lottery results are officially posted.", yearRange: "Marketing & Closeout" },
  { date: "August 29, 2024", category: "progress", year: "2024", text: "Permanent power to the switchgear is finally energized by PG&E, allowing for final unit meter installation and systems commissioning.", yearRange: "Marketing & Closeout" },
  { date: "Sept 10, 2024", category: "progress", year: "2024", text: "Final window passes its water test in Unit 316, officially completing the window testing scope after over a year of struggles.", yearRange: "Marketing & Closeout" },
  { date: "Dec 10, 2024", category: "progress", year: "2024", text: "The City's Department of Building Inspection issues an Amended Temporary Certificate of Occupancy (TCO) for the 148-unit building.", yearRange: "Marketing & Closeout" },

  // 2025
  { date: "Jan 8, 2025", category: "progress", year: "2025", text: "The project officially receives its Final Certificate of Occupancy, and units are ready to be occupied upon loan closings.", yearRange: "Occupancy & Governance" },
  { date: "Jan 17, 2025", category: "governance", year: "2025", text: "Original Management Agreement executed with Seabreeze Management.", yearRange: "Occupancy & Governance" },
  { date: "May 8, 2025", category: "governance", year: "2025", text: "The first homeowner unit is officially closed, marking the transition of the building to an active Common Interest Development.", yearRange: "Occupancy & Governance" },
  { date: "June 20, 2025", category: "marketing", year: "2025", text: "A new marketing campaign launches to sell four remaining accessible BMR units on a First-Come, First-Served (FCFS) basis.", yearRange: "Occupancy & Governance" },
  { date: "July 1, 2025", category: "sales", year: "2025", text: "Applications officially open for the FCFS accessible units.", yearRange: "Occupancy & Governance" },
  { date: "Aug 20, 2025", category: "governance", year: "2025", text: "The Board sends a formal notice of intent to terminate the Seabreeze Management contract.", yearRange: "Occupancy & Governance" },
  { date: "Aug 21, 2025", category: "governance", year: "2025", text: "Action Property Management contract executed, initiating the transition for exclusive managing agency.", yearRange: "Occupancy & Governance" },
  { date: "Oct 10, 2025", category: "governance", year: "2025", text: "The building reaches a major sales milestone: 50%+1 of the units are officially closed.", yearRange: "Occupancy & Governance" },
  { date: "October 21, 2025", category: "marketing", year: "2025", text: "Another FCFS marketing launch begins to sell off the final remaining unsold units.", yearRange: "Occupancy & Governance" },
  { date: "Oct 31, 2025", category: "governance", year: "2025", text: "Transition of management duties from Seabreeze to Action Property Management is completed.", yearRange: "Occupancy & Governance" },
  { date: "November 3, 2025", category: "sales", year: "2025", text: "Applications open for the November round of remaining FCFS units.", yearRange: "Occupancy & Governance" },
  { date: "Nov 6, 2025", category: "governance", year: "2025", text: "The Association holds its first official Board of Directors meeting.", yearRange: "Occupancy & Governance" },

  // 2026
  { date: "Jan 16, 2026", category: "governance", year: "2026", text: "Conversion Point: Per Section 5.4 of the CC&R, voting rights transition from Class B (Developer, 3 votes/unit) to Class A (Owner, 1 vote/unit).", yearRange: "Active Governance & Elections" },
  { date: "Feb 17, 2026", category: "governance", year: "2026", text: "Second Board Meeting: Board reviews and distributes proposed Election Rules to the membership for the 28-day comment period.", yearRange: "Active Governance & Elections" },
  { date: "Mar 24, 2026", category: "governance", year: "2026", text: "Third Board Meeting: Board officially adopts the new Election Rules following the member comment period.", yearRange: "Active Governance & Elections" },
  { date: "Apr 7, 2026", category: "governance", year: "2026", text: "Pro Elections begins the first homeowner Board election process, initiating the call for nominations.", yearRange: "Active Governance & Elections" },
  { date: "July 24, 2026", category: "governance", year: "2026", text: "Scheduled date for the first Annual Meeting and homeowner Board election.", yearRange: "Active Governance & Elections" },
];

const categories = [
  { id: 'funding', label: 'Funding', color: 'bg-emerald-100 text-emerald-800' },
  { id: 'progress', label: 'Progress', color: 'bg-blue-100 text-blue-800' },
  { id: 'delay', label: 'Delays', color: 'bg-rose-100 text-rose-800' },
  { id: 'governance', label: 'Governance', color: 'bg-slate-100 text-slate-800' },
  { id: 'marketing', label: 'Marketing', color: 'bg-purple-100 text-purple-800' },
  { id: 'lottery', label: 'Lottery', color: 'bg-amber-100 text-amber-800' },
  { id: 'sales', label: 'Sales', color: 'bg-indigo-100 text-indigo-800' },
];

const years = ['all', '2019', '2020', '2021', '2022', '2023', '2024', '2025', '2026'];
---

<BaseLayout title="Development History & Timeline">
	<div class="mb-12">
		<h1 class="text-4xl font-extrabold text-slate-900 mb-4">Development History & Timeline</h1>
		<p class="text-lg text-slate-600 max-w-3xl">
			A chronological history of the 400 China Basin development, from early entitlements to final occupancy.
		</p>
	</div>

	<!-- Unit Closing Progress Chart -->
	<section class="mb-20 bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
		<div class="flex flex-col lg:flex-row gap-12 items-center">
			<div class="lg:w-1/3">
				<h2 class="text-2xl font-black text-slate-900 mb-2">Unit Closing Progress</h2>
				<p class="text-slate-500 mb-2 font-medium leading-relaxed">
					Tracking cumulative homeowner unit closings from building completion through today.
				</p>
				<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-1">
					<span class="text-blue-500">Source:</span> SF Assessor & Recorder Office
				</p>
				<div class="grid grid-cols-2 gap-4">
					<div class="bg-blue-50 p-4 rounded-2xl border border-blue-100">
						<span class="block text-xs font-black text-blue-800 uppercase tracking-widest mb-1">Closed</span>
						<span class="text-3xl font-black text-blue-900">{currentClosed}</span>
						<span class="text-sm font-bold text-blue-600 ml-1">/ {totalUnits}</span>
					</div>
					<div class="bg-emerald-50 p-4 rounded-2xl border border-emerald-100">
						<span class="block text-xs font-black text-emerald-800 uppercase tracking-widest mb-1">Absorption</span>
						<span class="text-3xl font-black text-emerald-900">{absorptionRate}%</span>
					</div>
				</div>
			</div>

			<div class="lg:w-2/3 w-full" x-data={JSON.stringify({ activePoint: null, data: closings })} @mouseleave="activePoint = null">
				<div class="relative pt-4">
					<!-- Y-Axis Labels -->
					<div class="absolute -left-2 top-4 bottom-8 flex flex-col justify-between text-[10px] font-bold text-slate-400 text-right w-8">
						<span>150</span>
						<span>100</span>
						<span>50</span>
						<span>0</span>
					</div>

					<div class="ml-10">
						<svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="w-full h-auto overflow-visible" preserveAspectRatio="none">
							<!-- Grid Lines -->
							<line x1="0" y1="0" x2={chartWidth} y2="0" stroke="#f1f5f9" stroke-width="1" />
							<line x1="0" y1={chartHeight/3} x2={chartWidth} y2={chartHeight/3} stroke="#f1f5f9" stroke-width="1" />
							<line x1="0" y1={(chartHeight/3)*2} x2={chartWidth} y2={(chartHeight/3)*2} stroke="#f1f5f9" stroke-width="1" />
							<line x1="0" y1={chartHeight} x2={chartWidth} y2={chartHeight} stroke="#e2e8f0" stroke-width="2" />

							<!-- Main Line -->
							<polyline
								fill="none"
								stroke="#2563eb"
								stroke-width="4"
								stroke-linecap="round"
								stroke-linejoin="round"
								points={points}
								class="drop-shadow-sm"
							/>

							<!-- Interaction Points -->
							{closings.map((d, i) => {
								const x = (i / (closings.length - 1)) * chartWidth;
								const y = chartHeight - (d.total / maxTotal) * chartHeight;
								return (
									<g 
										@mouseenter={`activePoint = ${i}`} 
										class="cursor-pointer"
									>
										<circle 
											cx={x} cy={y} r="6" 
											fill={i === closings.length - 1 ? "#2563eb" : "white"} 
											stroke="#2563eb" 
											stroke-width="3" 
											class="transition-all duration-200"
											:r={`activePoint === ${i} ? 8 : 6`}
										/>
										<!-- Transparent hit area for better hover -->
										<rect x={x - (chartWidth / (closings.length - 1) / 2)} y="0" width={chartWidth / (closings.length - 1)} height={chartHeight} fill="transparent" />
									</g>
								);
							})}
						</svg>

						<!-- Tooltip -->
						<template x-if="activePoint !== null">
							<div 
								class="absolute bg-slate-900 text-white p-3 rounded-xl shadow-xl text-xs pointer-events-none z-50 w-36"
								:style="`left: ${(activePoint / (data.length - 1)) * 100}%; top: 0; transform: translate(-50%, -120%)`"
							>
								<div class="font-black text-blue-400 mb-1" x-text="data[activePoint].month"></div>
								<div class="flex justify-between items-end mb-1">
									<span class="opacity-70">Total Closed:</span>
									<span class="text-sm font-black" x-text="data[activePoint].total"></span>
								</div>
								<div class="flex justify-between items-end text-[10px] border-t border-slate-700 pt-1 mt-1">
									<span class="opacity-70">New This Month:</span>
									<span class="font-bold text-emerald-400" x-text="`+${data[activePoint].new}`"></span>
								</div>
							</div>
						</template>

						<!-- X-Axis Labels -->
						<div class="flex justify-between mt-4">
							<span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{closings[0].month.split(' ')[0]} '{closings[0].month.split(' ')[1].slice(2)}</span>
							<span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Dec '25</span>
							<span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">{closings[closings.length - 1].month.split(' ')[0]} '{closings[closings.length - 1].month.split(' ')[1].slice(2)}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div 
    x-data={`{ 
      activeYear: 'all', 
      sortOrder: 'asc',
      events: ${JSON.stringify(timelineEvents)},
      categories: ${JSON.stringify(categories)},
      get filteredEvents() {
        let filtered = this.activeYear === 'all' 
          ? this.events 
          : this.events.filter(e => e.year === this.activeYear);
        
        return this.sortOrder === 'asc' 
          ? filtered 
          : [...filtered].reverse();
      }
    }`} 
    class="space-y-10"
  >
		<!-- Filter & Sort Navigation -->
		<div class="space-y-4 sticky top-20 z-40">
			<div class="flex flex-col md:flex-row gap-4">
				<!-- Year Filter -->
				<div class="flex-grow bg-white border border-slate-200 rounded-2xl p-1.5 shadow-sm overflow-x-auto">
					<div class="flex gap-1 min-w-max">
						<div class="px-3 py-2 text-xs font-black text-slate-400 uppercase tracking-widest flex items-center">Filter Year:</div>
						{years.map(y => (
							<button 
								@click={`activeYear = '${y}'`}
								:class={`activeYear === '${y}' ? 'bg-blue-600 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-50'`}
								class="px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200"
							>
								{y === 'all' ? 'All' : y}
							</button>
						))}
					</div>
				</div>

				<!-- Sort Toggle -->
				<div class="bg-slate-900 border border-slate-800 rounded-2xl p-1.5 shadow-lg flex-shrink-0">
					<div class="flex gap-1">
						<button 
							@click="sortOrder = 'asc'"
							:class="sortOrder === 'asc' ? 'bg-white text-slate-900 shadow-md' : 'text-slate-400 hover:text-white'"
							class="px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200"
						>
							Oldest First
						</button>
						<button 
							@click="sortOrder = 'desc'"
							:class="sortOrder === 'desc' ? 'bg-white text-slate-900 shadow-md' : 'text-slate-400 hover:text-white'"
							class="px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200"
						>
							Latest First
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Timeline Content -->
		<div class="max-w-5xl mx-auto">
			<div class="space-y-12">
        <template x-for="(event, index) in filteredEvents" :key="index">
          <div>
            <!-- Stage Header: Only show if yearRange changes AND we aren't filtering to a specific year -->
            <template x-if="activeYear === 'all' && (index === 0 || filteredEvents[index - 1].yearRange !== event.yearRange)">
              <div class="relative py-12 first:pt-0">
                <div class="flex items-center gap-4">
                  <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight" x-text="event.yearRange"></h2>
                  <div class="h-px flex-grow bg-slate-200"></div>
                </div>
              </div>
            </template>

            <div 
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 transform translate-y-4"
              x-transition:enter-end="opacity-100 transform translate-y-0"
              class="group flex flex-col md:flex-row gap-6 md:gap-12 mb-12"
            >
              <!-- Left Column: Date -->
              <div class="md:w-48 md:shrink-0 md:text-right">
                <div class="sticky top-44">
                  <div class="text-lg font-black text-slate-900 leading-tight group-hover:text-blue-700 transition-colors" x-text="event.date"></div>
                </div>
              </div>

              <!-- Connection Dot & Line -->
              <div class="hidden md:flex flex-col items-center">
                <div 
                  class="w-4 h-4 rounded-full border-4 border-white shadow-sm z-10"
                  :class="categories.find(c => c.id === event.category)?.color.split(' ')[0] || 'bg-slate-200'"
                ></div>
                <div class="w-1 h-full bg-slate-100 -mt-1"></div>
              </div>

              <!-- Right Column: Content -->
              <div class="flex-grow bg-white border border-slate-200 rounded-2xl p-6 shadow-sm group-hover:shadow-md group-hover:border-slate-300 transition-all duration-300">
                <div class="flex items-center gap-3 mb-3">
                  <span 
                    class="px-2.5 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider"
                    :class="categories.find(c => c.id === event.category)?.color"
                    x-text="categories.find(c => c.id === event.category)?.label"
                  >
                  </span>
                </div>
                <p class="text-slate-700 leading-relaxed text-lg font-medium" x-text="event.text">
                </p>
              </div>
            </div>
          </div>
        </template>
			</div>
		</div>

		<!-- Footer Sources -->
		<footer class="mt-20 pt-12 border-t border-slate-200 bg-slate-50 rounded-3xl p-8">
			<h4 class="text-lg font-black text-slate-900 mb-6 uppercase tracking-wider flex items-center gap-2">
				<span class="w-8 h-8 bg-slate-900 text-white rounded-lg flex items-center justify-center text-xs">ℹ️</span>
				Sources Cited & Disclosures
			</h4>
			<p class="text-sm text-slate-500 italic mb-8 leading-relaxed max-w-3xl">
				These documents were requested via the Sunshine Ordinance from the Office of Community Investment and Infrastructure (OCII) and the Mayor's Office of Housing and Community Development (MOHCD).
			</p>
			
			<div class="grid md:grid-cols-2 gap-10">
				<div class="space-y-4">
					<h5 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-200 pb-2">Agreements & Agency Records</h5>
					<ul class="text-sm text-slate-600 space-y-3">
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> Disposition and Development Agreement (executed 6/30/22)</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> Amended and Restated Loan Agreement ($75.2M, 6/30/22)</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> First Amendment to A&R Loan Agreement (1/16/24)</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> OCII RESO 02-2020, 07-2021, 14-2022, 04-2024</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> MOHCD/OCII Loan Committee Evaluations</li>
					</ul>
				</div>
				<div class="space-y-4">
					<h5 class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-200 pb-2">Construction & Marketing</h5>
					<ul class="text-sm text-slate-600 space-y-3">
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> OAC Meeting Minutes (Nos. 12-128, 2022–2024)</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> MB9A May 2024 Schedule Narrative</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> DBI Amended Temporary Certificate of Occupancy (TCO)</li>
						<li class="flex gap-3 items-start"><span class="text-blue-500 font-bold">•</span> BMR Ownership Marketing Plans (2024, 2025)</li>
					</ul>
				</div>
			</div>
		</footer>
	</div>

	<!-- Alpine.js for filtering -->
	<script is:inline src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</BaseLayout>
