---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Financials & Budgets">
	<div class="mb-12">
		<h1 class="text-4xl font-extrabold text-slate-900 mb-4">Financials & Budgets</h1>
		<p class="text-lg text-slate-600 max-w-3xl">
			Transparent access to our community's financial health. Review budget summaries, 
			audited statements, and a searchable ledger of recent expenditures.
		</p>
	</div>

	<div class="p-16 text-center bg-slate-50 border-2 border-dashed border-slate-200 rounded-3xl">
		<div class="text-5xl mb-6">📊</div>
		<h2 class="text-2xl font-bold text-slate-900 mb-2">Financial Records Coming Soon</h2>
		<p class="text-slate-500 max-w-md mx-auto leading-relaxed">
			We are currently parsing and auditing the community financial records. 
			Check back later for the <strong>2025 Financials</strong> and a detailed <strong>2025 & 2026 Budget Breakdown</strong>.
		</p>
	</div>
</BaseLayout>
