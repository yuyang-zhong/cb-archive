---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TakeawayCard from '../../components/TakeawayCard.astro';

export async function getStaticPaths() {
  const entries = await getCollection('contracts');
  return entries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title}>
	<div class="max-w-4xl mx-auto" data-pagefind-filter="Section:Contracts">
		<a href="/cb-archive/contracts" class="text-blue-700 text-sm font-medium hover:underline mb-8 inline-block" data-pagefind-ignore>← Back to Contracts</a>
		<header class="mb-10">
			<div class="flex flex-col lg:flex-row lg:items-start justify-between gap-6 mb-6">
				<div class="flex-1">
					<div class="flex items-center gap-3 mb-3">
						<h1 class="text-4xl font-extrabold text-slate-900">{entry.data.title}</h1>
						<span class={`px-3 py-1 rounded-full text-xs font-black uppercase tracking-widest border ${
							entry.data.status === 'Active' ? 'bg-green-50 text-green-700 border-green-200' : 
							entry.data.status === 'Terminated' ? 'bg-red-50 text-red-700 border-red-200' : 
							'bg-slate-50 text-slate-600 border-slate-200'
						}`}>
							{entry.data.status}
						</span>
					</div>
					<p class="text-xl text-slate-600 leading-relaxed mb-4">{entry.data.description}</p>
					
					<div class="flex flex-wrap gap-6 text-sm font-bold text-slate-400 uppercase tracking-widest">
						{entry.data.executedDate && (
							<div>
								<span class="opacity-60 block text-[10px] mb-1 text-slate-500">Executed Date</span>
								<span class="text-slate-700">{entry.data.executedDate}</span>
							</div>
						)}
						{entry.data.terminationDate && (
							<div>
								<span class="opacity-60 block text-[10px] mb-1 text-red-500">Termination Date</span>
								<span class="text-red-700">{entry.data.terminationDate}</span>
							</div>
						)}
					</div>
				</div>
				<div class="flex flex-col gap-3 min-w-[200px]">
					{entry.data.cost && (
						<div class="bg-blue-600 text-white px-8 py-5 rounded-3xl shadow-xl shadow-blue-100 text-center">
							<span class="block text-[10px] uppercase tracking-widest font-bold opacity-80 mb-1">Recurring Cost</span>
							<span class="text-3xl font-black">{entry.data.cost}</span>
						</div>
					)}
					{entry.data.oneTimeCost && (
						<div class="bg-amber-100 border border-amber-200 text-amber-900 px-6 py-3 rounded-2xl text-center">
							<span class="block text-[10px] uppercase tracking-widest font-bold text-amber-700 mb-0.5">One-Time Fee</span>
							<span class="text-xl font-black">{entry.data.oneTimeCost}</span>
						</div>
					)}
				</div>
			</div>
		</header>
		{entry.data.keyTakeaways && <TakeawayCard title={entry.data.title} takeaways={entry.data.keyTakeaways} />}
		<article class="prose prose-slate prose-lg max-w-none 
			prose-headings:text-slate-900 prose-headings:font-bold prose-headings:tracking-tight
			prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
			prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
			prose-a:text-blue-700 hover:prose-a:text-blue-800
			prose-strong:text-slate-900">
			<Content />
		</article>
		<div class="mt-12 p-6 border border-slate-200 rounded-xl bg-white">
			<h3 class="font-bold text-slate-900 mb-2">Official Record Request</h3>
			<p class="text-slate-600 text-sm leading-relaxed">
				Pursuant to California Civil Code § 5230, and due to the public nature of this website, public downloads of association contracts and membership records are not available. Please review the official HOA portal or reach out to management to request a copy of this record. <a href="/cb-archive/#records-request" class="text-blue-700 hover:underline font-medium">Learn more about requesting records.</a>
			</p>
		</div>
	</div>
</BaseLayout>
