---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = await getCollection('parking');
---
<BaseLayout title="Neighborhood Parking">
	<div class="mb-12">
		<h1 class="text-4xl font-extrabold text-slate-900 mb-4">Neighborhood Parking</h1>
		<p class="text-lg text-slate-600 max-w-3xl">Guidelines for residents and guests, including maps and registration.</p>
	</div>
	<div class="space-y-6">
		{docs.length === 0 ? <p class="italic text-slate-500">No parking documents found.</p> : docs.map(doc => (
			<div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
				<h2 class="text-xl font-bold mb-2">{doc.data.title}</h2>
				<p class="text-slate-600 mb-4">{doc.data.description}</p>
				<a href={`/parking/${doc.id}`} class="text-blue-700 font-semibold hover:underline">Parking Rules →</a>
			</div>
		))}
	</div>
</BaseLayout>
